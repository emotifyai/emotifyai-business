{
    "name": "emotifyai",
    "version": "0.1.1",
    "private": true,
    "description": "AI-powered text enhancement platform - Monorepo containing browser extension and web application",
    "type": "module",
    "packageManager": "bun@1.3.5",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "dev:ext": "cd apps/extension && bun run dev",
        "dev:web": "cd apps/web && bun run dev",
        "build": "turbo run build",
        "build:ext": "cd apps/extension && bun run build",
        "build:web": "cd apps/web && bun run build",
        "test": "turbo run test",
        "test:ext": "cd apps/extension && bun run test",
        "test:web": "cd apps/web && bun run test",
        "test:coverage": "turbo run test:coverage",
        "test:ext:coverage": "cd apps/extension && bun run test:coverage",
        "test:web:coverage": "cd apps/web && bun run test:coverage",
        "typecheck": "turbo run typecheck",
        "install:all": "bun install",
        "zip:ext": "cd apps/extension && bun run zip",
        "zip:ext:firefox": "cd apps/extension && bun run zip:firefox"
    },
    "catalog": {
        "typescript": "^6.0.3",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "tailwindcss": "^4.1.18",
        "turbo": "^2.9.14",
        "@tanstack/react-query": "^5.90.12",
        "@tanstack/react-query-devtools": "^5.90.12",
        "eslint": "^9.39.2",
        "sharp": "^0.34.5",
        "@types/sharp": "^0.32.0",
        "lucide-react": "^0.562.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "turbo": "catalog:"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "engines": {
        "bun": ">=1.2.21",
        "node": ">=20.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/yourusername/emotifyai-monorepo"
    },
    "keywords": [
        "ai",
        "text-enhancement",
        "browser-extension",
        "nextjs",
        "react",
        "typescript",
        "supabase",
        "claude",
        "monorepo"
    ],
    "author": "EmotifyAI",
    "license": "PROPRIETARY",
    "overrides": {
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3"
    }
}
